# === Telegram ===
TELEGRAM_MODE=bot                        # bot: Bot API / account: User account (MTProto)
TELEGRAM_CHANNEL_ID=                     # e.g. @my_channel or -100xxxxxxxxxx
TELEGRAM_BOT_TOKEN=                      # From @BotFather

# === Monitoring ===
MONITOR_INTERVAL_MIN=3                   # Min wait time (minutes)
MONITOR_INTERVAL_MAX=6                   # Max wait time (minutes)

# === Search Filters ===
SEARCH_CATEGORY=it-programming           # -> clicks #category-it-programming
SEARCH_LANGUAGE=xx                       # xx=All, en=English, es=Español, pt=Português

# === Browser ===
BROWSER_HEADLESS=false                   # true: background / false: visible window

# === Proxy ===
PROXY_URL=                               # e.g. socks5://user:pass@host:port

# === Posting ===
TIMEZONE=Asia/Tokyo                      # Output timezone
MAX_BUDGET=500                           # Min budget to post (0=no filter)
MAX_PAGES_PER_CYCLE=5                    # Max pages per cycle
